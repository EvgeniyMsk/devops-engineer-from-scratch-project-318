# Shared locations — included from HTTP/HTTPS server blocks
client_max_body_size {{ nginx_client_max_body_size }};

location /assets/ {
    root {{ nginx_static_root }};
    try_files $uri @app;
    expires 7d;
    add_header Cache-Control "public, immutable";
    access_log off;
}

location = /favicon.ico {
    root {{ nginx_static_root }};
    try_files $uri @app;
    expires 7d;
    add_header Cache-Control "public, immutable";
    access_log off;
}

location = /manifest.json {
    root {{ nginx_static_root }};
    try_files $uri @app;
    expires 1d;
    add_header Cache-Control "public";
    access_log off;
}

location = /robots.txt {
    root {{ nginx_static_root }};
    try_files $uri @app;
    expires 1d;
    add_header Cache-Control "public";
    access_log off;
}

location ~* \.(?:css|js|mjs|map|woff2?|ttf|eot|svg|png|jpg|jpeg|gif|webp|ico)$ {
    proxy_pass http://bulletin_app;
    proxy_http_version 1.1;
    proxy_set_header Connection "";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    proxy_cache bulletins_cache;
    proxy_cache_valid 200 7d;
    proxy_cache_use_stale error timeout updating http_500 http_502 http_503 http_504;
    proxy_cache_lock on;
    add_header X-Cache-Status $upstream_cache_status always;
    expires 7d;
    add_header Cache-Control "public";
}

location /api/files/raw {
    proxy_pass http://bulletin_app;
    proxy_http_version 1.1;
    proxy_set_header Connection "";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    proxy_cache bulletins_cache;
    proxy_cache_valid 200 1d;
    proxy_cache_use_stale error timeout updating http_500 http_502 http_503 http_504;
    add_header X-Cache-Status $upstream_cache_status always;
}

location /api/ {
    proxy_pass http://bulletin_app;
    proxy_http_version 1.1;
    proxy_set_header Connection "";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_read_timeout 300s;
    proxy_cache off;
}

location = /index.html {
    proxy_pass http://bulletin_app;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    add_header Cache-Control "no-cache";
}

location / {
    proxy_pass http://bulletin_app;
    proxy_http_version 1.1;
    proxy_set_header Connection "";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
}

location @app {
    proxy_pass http://bulletin_app;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
}
