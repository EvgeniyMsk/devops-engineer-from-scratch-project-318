      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"docker\", service=\"application\", app=\"$app\"} | json | level=\"ERROR\" [$__interval]))",
          "legendFormat": "errors",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Application ERROR logs",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 14 },
      "id": 5,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (status) (count_over_time({job=\"nginx-access\", app=\"$app\"} | json | __error__=\"\" | status != \"\" [$__interval]))",
          "legendFormat": "HTTP {{status}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "HTTP status codes (nginx access log)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
