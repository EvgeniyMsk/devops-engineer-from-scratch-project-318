      "targets": [
        {
          "expr": "{app=\"$app\", env=\"$env\"} | json | message =~ \"(?i).*$user.*\" or remote_addr =~ \".*$user.*\" or username =~ \".*$user.*\" or user =~ \".*$user.*\"",
          "refId": "A"
        }
      ],
      "title": "Search by user / IP",
      "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 8 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"nginx-access\", app=\"$app\"} | json | status >= 500 [$__interval]))",
          "legendFormat": "5xx",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Nginx 5xx (count in range)",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
