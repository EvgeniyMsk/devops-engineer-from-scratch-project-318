      "id": 3,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["max"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        {
          "expr": "max(max_over_time({job=\"nginx-access\", app=\"$app\"} | json | unwrap request_time [$__interval]))",
          "legendFormat": "max request_time",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Max request latency (nginx)",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
