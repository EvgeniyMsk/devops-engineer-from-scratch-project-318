      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "id": 3,
      "targets": [
        {
          "expr": "node_filesystem_avail_bytes{job=~\"$job\", instance=~\"$instance\", mountpoint=\"/\", fstype!~\"tmpfs|overlay|squashfs\"}",
          "legendFormat": "avail /",
          "refId": "A"
        },
        {
          "expr": "node_filesystem_size_bytes{job=~\"$job\", instance=~\"$instance\", mountpoint=\"/\", fstype!~\"tmpfs|overlay|squashfs\"}",
          "legendFormat": "size /",
          "refId": "B"
        }
      ],
      "title": "Disk (root)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 4,
      "targets": [
        { "expr": "rate(node_network_receive_bytes_total{job=~\"$job\", instance=~\"$instance\", device!=\"lo\"}[5m])", "legendFormat": "{{device}} rx", "refId": "A" },
