      "targets": [{ "expr": "nginx_connections_active{job=~\"$job\", instance=~\"$instance\"}", "legendFormat": "active", "refId": "A" }],
      "title": "Active connections",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "expr": "sum(rate(nginx_http_requests_total{job=~\"$job\", instance=~\"$instance\"}[5m]))", "legendFormat": "RPS", "refId": "A" }],
      "title": "Nginx RPS (total)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "description": "5xx из Actuator (приложение должно быть запущено). Nginx 502 при падении upstream сюда не попадает.",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "expr": "sum(rate(http_server_requests_seconds_count{job=\"bulletins-app\", status=~\"5..\"}[5m])) or on() vector(0)", "legendFormat": "5xx", "refId": "A" }],
      "title": "Upstream 5xx RPS (Actuator)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "id": 4,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket{job=\"bulletins-app\"}[5m])))", "legendFormat": "p95", "refId": "A" }],
      "title": "Upstream latency p95",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "id": 5,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "nginx_connections_active{job=~\"$job\", instance=~\"$instance\"}", "legendFormat": "active", "refId": "A" },
        { "expr": "nginx_connections_reading{job=~\"$job\", instance=~\"$instance\"}", "legendFormat": "reading", "refId": "B" },
        { "expr": "nginx_connections_writing{job=~\"$job\", instance=~\"$instance\"}", "legendFormat": "writing", "refId": "C" },
        { "expr": "nginx_connections_waiting{job=~\"$job\", instance=~\"$instance\"}", "legendFormat": "waiting", "refId": "D" }
      ],
      "title": "Connection states",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "id": 6,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [{ "expr": "sum(rate(nginx_http_requests_total{job=~\"$job\", instance=~\"$instance\"}[5m]))", "legendFormat": "nginx RPS", "refId": "A" }],
      "title": "Nginx request rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 13 },
      "id": 7,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [{ "expr": "sum by (status) (rate(http_server_requests_seconds_count{job=\"bulletins-app\"}[5m]))", "legendFormat": "HTTP {{status}}", "refId": "A" }],
      "title": "HTTP response codes (upstream app)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 13 },
      "id": 8,
      "targets": [{ "expr": "histogram_quantile(0.95, sum by (le, status) (rate(http_server_requests_seconds_bucket{job=\"bulletins-app\"}[5m])))", "legendFormat": "p95 status={{status}}", "refId": "A" }],
      "title": "Upstream latency p95 by status",
      "type": "timeseries"
    }
  ],
