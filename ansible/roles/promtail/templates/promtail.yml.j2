server:
  http_listen_port: {{ promtail_listen_port }}
  grpc_listen_port: 0
  log_level: info

positions:
  filename: {{ promtail_positions_file }}

clients:
  - url: {{ promtail_loki_url | to_json }}
{% if promtail_loki_basic_auth_username | default('') | length > 0 %}
    basic_auth:
      username: {{ promtail_loki_basic_auth_username | to_json }}
      password: {{ promtail_loki_basic_auth_password | to_json }}
{% endif %}

scrape_configs:
  - job_name: docker-containers
    docker_sd_configs:
      - host: unix:///var/run/docker.sock
        refresh_interval: 5s
    relabel_configs:
      - source_labels: ['__meta_docker_container_name']
        regex: '/?(.*)'
        target_label: container
      - source_labels: ['__meta_docker_container_name']
        regex: '/({{ promtail_docker_containers | join("|") }})'
        action: keep
      - target_label: job
        replacement: docker
      - target_label: env
        replacement: {{ logging_env | to_json }}
      - target_label: app
        replacement: {{ logging_app | to_json }}
      - target_label: host
        replacement: {{ inventory_hostname | to_json }}
      - source_labels: ['__meta_docker_container_name']
        regex: '/application.*'
        replacement: application
        target_label: service
      - source_labels: ['__meta_docker_container_name']
        regex: '/database.*'
        replacement: database
        target_label: service
    pipeline_stages:
      - cri: {}
      - json:
          expressions:
            level: level
            logger: logger
            message: message
            timestamp: timestamp
            user: user
            username: username
          source: log
      - labels:
          level:
          service:
      - timestamp:
          source: timestamp
          format: RFC3339Nano
          fallback_formats:
            - RFC3339
            - "2006-01-02 15:04:05.999"
          action_on_failure: fudge

  - job_name: application-files
    static_configs:
      - targets: [localhost]
        labels:
          job: application
          env: {{ logging_env | to_json }}
          app: {{ logging_app | to_json }}
          host: {{ inventory_hostname | to_json }}
          __path__: {{ app_log_dir }}/*.log
    pipeline_stages:
      - json:
          expressions:
            level: level
            message: message
            timestamp: timestamp
            user: user
            username: username
      - labels:
          level:
      - timestamp:
          source: timestamp
          format: RFC3339Nano
          fallback_formats:
            - RFC3339
          action_on_failure: fudge

  - job_name: nginx-access
    static_configs:
      - targets: [localhost]
        labels:
          job: nginx-access
          env: {{ logging_env | to_json }}
          app: {{ logging_app | to_json }}
          host: {{ inventory_hostname | to_json }}
          __path__: {{ nginx_app_access_log }}
    pipeline_stages:
      - json:
          expressions:
            status: status
            request_time: request_time
            request_uri: request_uri
            remote_addr: remote_addr
            upstream_response_time: upstream_response_time
            request_method: request_method
            time: time
      - labels:
          status:
      - timestamp:
          source: time
          format: RFC3339
          action_on_failure: fudge

  - job_name: nginx-monitoring
    static_configs:
      - targets: [localhost]
        labels:
          job: nginx-monitoring
          env: {{ logging_env | to_json }}
          app: {{ logging_app | to_json }}
          host: {{ inventory_hostname | to_json }}
          __path__: {{ nginx_monitoring_access_log }}
    pipeline_stages:
      - json:
          expressions:
            status: status
            request_time: request_time
            request_uri: request_uri
            remote_addr: remote_addr
            time: time
      - labels:
          status:
      - timestamp:
          source: time
          format: RFC3339
          action_on_failure: fudge

  - job_name: nginx-error
    static_configs:
      - targets: [localhost]
        labels:
          job: nginx-error
          env: {{ logging_env | to_json }}
          app: {{ logging_app | to_json }}
          host: {{ inventory_hostname | to_json }}
          __path__: {{ nginx_app_error_log }}
    pipeline_stages:
      - regex:
          expression: '^(?P<time>\d{4}/\d{2}/\d{2} \d{2}:\d{2}:\d{2}) \[(?P<level>\w+)\].*?(?P<message>.*)$'
      - labels:
          level:
      - timestamp:
          source: time
          format: "2006/01/02 15:04:05"
          action_on_failure: fudge
