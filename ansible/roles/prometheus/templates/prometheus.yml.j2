global:
  scrape_interval: 15s
  scrape_timeout: 10s

rule_files:
  - /etc/prometheus/rules/*.yml

scrape_configs:
{% for job in prometheus_scrape_jobs %}
  - job_name: {{ job.job_name | to_json }}
    metrics_path: {{ job.metrics_path | to_json }}
    scheme: {{ job.scheme | to_json }}
    static_configs:
      - targets:
{% for target in job.targets %}
          - {{ target | to_json }}
{% endfor %}
{% endfor %}
