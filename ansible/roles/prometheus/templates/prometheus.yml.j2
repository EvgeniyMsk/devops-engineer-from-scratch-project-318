global:
  scrape_interval: 15s
  scrape_timeout: 10s

scrape_configs:
  - job_name: node
    metrics_path: /metrics
    scheme: https
    static_configs:
      - targets:
          - "{{ prometheus_scrape_target }}"

  - job_name: bulletins-app
    metrics_path: /actuator/prometheus
    scheme: https
    static_configs:
      - targets:
          - "{{ prometheus_scrape_target }}"
