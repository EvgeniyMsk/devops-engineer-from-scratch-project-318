# Managed by Ansible — reverse proxy for bulletin board application
upstream bulletin_app {
    server 127.0.0.1:{{ app_http_port }};
    keepalive 32;
}

upstream bulletin_management {
    server 127.0.0.1:{{ app_management_upstream_port }};
    keepalive 8;
}

upstream node_exporter {
    server 127.0.0.1:{{ node_exporter_port }};
    keepalive 4;
}

# HTTP: ACME challenge + redirect to HTTPS when certificate is available
server {
    listen 80;
    listen [::]:80;
    server_name {{ certbot_domain }};

    access_log /var/log/nginx/bulletins-access.log;
    error_log /var/log/nginx/bulletins-error.log warn;

    location ^~ /.well-known/acme-challenge/ {
        alias {{ certbot_webroot }}/.well-known/acme-challenge/;
        default_type "text/plain";
        allow all;
    }

{% if nginx_ssl_enabled | bool %}
    location / {
        return 301 https://$host$request_uri;
    }
{% else %}
    location / {
        return 404;
    }
{% endif %}
}

{% if nginx_ssl_enabled | bool %}
# HTTPS: application traffic with modern TLS settings
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name {{ certbot_domain }};

    ssl_certificate {{ certbot_cert_path }}/fullchain.pem;
    ssl_certificate_key {{ certbot_cert_path }}/privkey.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305;
    ssl_session_timeout 1d;
    ssl_session_cache shared:BulletinsSSL:10m;
    ssl_session_tickets off;

    resolver 1.1.1.1 8.8.8.8 valid=300s ipv6=off;
    resolver_timeout 5s;

    ssl_stapling on;
    ssl_stapling_verify on;
    ssl_trusted_certificate {{ certbot_cert_path }}/chain.pem;

    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains" always;
    add_header X-Content-Type-Options nosniff always;
    add_header X-Frame-Options SAMEORIGIN always;

    access_log /var/log/nginx/bulletins-ssl-access.log;
    error_log /var/log/nginx/bulletins-ssl-error.log warn;

    include /etc/nginx/snippets/bulletins-locations.conf;
}

# Spring Boot Actuator — HTTPS metrics and health on dedicated port
server {
    listen {{ app_management_port }} ssl;
    listen [::]:{{ app_management_port }} ssl;
    server_name {{ certbot_domain }};

    ssl_certificate {{ certbot_cert_path }}/fullchain.pem;
    ssl_certificate_key {{ certbot_cert_path }}/privkey.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305;
    ssl_session_timeout 1d;
    ssl_session_cache shared:BulletinsSSL:10m;
    ssl_session_tickets off;

    access_log {{ nginx_monitoring_access_log }} monitoring_json;
    error_log {{ nginx_monitoring_error_log }} {{ nginx_monitoring_error_log_level }};

    include /etc/nginx/snippets/monitoring-locations.conf;

    location / {
        return 404;
    }
}
{% endif %}
